# tests/docker/Dockerfile.unit
#
# Lightweight image that compiles the library and runs only unit tests.
# Designed for fast CI feedback — no cross-compilation targets, no agent
# builds, no server binary. Full integration tests use the main Dockerfile.
#
# ┌──────────────────────────────────────────────────────────────────────┐
# │  Build stages                                                        │
# │                                                                      │
# │  deps     — download crates (cached layer, rarely re-runs)          │
# │  build    — compile the library in test mode                        │
# │  test     — run unit tests; non-zero exit = test failure            │
# └──────────────────────────────────────────────────────────────────────┘
#
# Usage:
#   # Run all unit tests for the new features
#   docker compose -f tests/docker/docker-compose.unit.yml up --build \
#     --abort-on-container-exit --exit-code-from unit-tests
#
#   # Run a single module
#   docker compose -f tests/docker/docker-compose.unit.yml \
#     run --rm unit-tests cargo test topology::tests -- --nocapture
#
# CI shorthand (no compose):
#   docker build -f tests/docker/Dockerfile.unit \
#     --target test --progress=plain .

# ── Stage 1: dependency cache ──────────────────────────────────────────
# Locked to the same Rust version used by the main Dockerfile so crate
# features and MSRV requirements are identical.
FROM rust:bookworm AS deps

# System libraries required by some crates at link time.
# libssl-dev   → reqwest / native-tls (indirect dep)
# pkg-config   → lets cargo find system libs
# libsqlite3   → rusqlite in non-bundled mode (we use bundled, but headers
#                are still needed for the proc-macro expansion on some crates)
# openssl      → certificate generation at build time
RUN apt-get update && apt-get install -y --no-install-recommends \
        libssl-dev pkg-config cmake openssl \
        python3 python3-venv python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy manifests first. Docker caches this layer until Cargo.toml/lock changes.
COPY Cargo.toml Cargo.lock* ./
COPY build.rs ./

# Stub out every [[bin]] source so `cargo fetch` resolves the full dep graph
# without needing the real source files. The stubs are replaced in stage 2.
RUN mkdir -p src/bin src/server src/agent/handlers src/agent/injection \
             src/api/routes src/api \
    && echo 'fn main() {}' > src/main.rs \
    && for b in server client builder client_dll client_service stager; do \
           echo 'fn main() {}' > "src/bin/${b}.rs"; \
       done \
    && echo 'pub fn _placeholder() {}' > src/lib.rs

RUN cargo fetch

# ── Stage 2: compile ───────────────────────────────────────────────────
FROM deps AS build

# Generate minimal TLS certificate bundle so include_bytes!("../certs/...")
# in transport.rs compiles. These are test-only self-signed certs — they
# are never used at runtime inside unit tests.
COPY gen_certs.sh ./
RUN bash gen_certs.sh ./certs

# Replace stubs with the real source tree.
COPY src/ ./src/
COPY tests/ ./tests/

# Unit tests don't use modules/ or extensions/ at runtime, but some crate
# build scripts expect the directories to exist. Create empty placeholders.
# COPY doesn't support shell redirection ("|| true") — use RUN instead.
RUN mkdir -p modules extensions

# Compile the library in test mode. --tests compiles all test harness
# binaries but does NOT run them yet; that happens in the next stage.
# We compile here so the test stage only needs to execute, not rebuild.
#
# LITECRYT_ENCRYPT_KEY: litcrypt requires a key at compile time. In
# production this is set from the build environment; for tests we supply
# a fixed dummy key. This does NOT affect test correctness — litcrypt only
# obfuscates string literals and the test binary uses the same key for
# both encryption and decryption.
ENV LITCRYPT_ENCRYPT_KEY="rcm-unit-test-dummy-key-0000000000"

RUN cargo test --no-run --locked 2>&1

# ── Stage 3: run tests ─────────────────────────────────────────────────
FROM build AS test

ENV RUST_TEST_NOCAPTURE=1
ENV RUST_BACKTRACE=1

# Default CMD: run ALL tests with no filter.
# The individual docker-compose services override this CMD with a specific
# filter (e.g. `topology::tests`) for targeted debugging only.
# Never use a filter here — that's how tests get silently excluded.
CMD ["cargo", "test", "--lib", "--", "--nocapture", "--test-threads=1"]
