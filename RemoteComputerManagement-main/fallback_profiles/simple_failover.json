{
  "_description": "Simple failover: try primary, fall to backup after 3 failures",
  "strategy": "failover",
  "dead_time_secs": 600,
  "endpoints": [
    {
      "host": "primary-c2.example.com",
      "port": 443,
      "transport": "https",
      "priority": 0,
      "max_failures": 3
    },
    {
      "host": "backup-c2.example.com",
      "port": 443,
      "transport": "https",
      "priority": 1,
      "max_failures": 5
    }
  ]
}
