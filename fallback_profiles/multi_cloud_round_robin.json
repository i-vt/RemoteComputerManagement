{
  "_description": "Round-robin across 3 cloud providers for resilience",
  "strategy": "round_robin",
  "dead_time_secs": 300,
  "endpoints": [
    {
      "host": "c2-aws.example.com",
      "port": 443,
      "transport": "https",
      "max_failures": 5,
      "weight": 1
    },
    {
      "host": "c2-azure.example.com",
      "port": 443,
      "transport": "https",
      "max_failures": 5,
      "weight": 1
    },
    {
      "host": "c2-gcp.example.com",
      "port": 443,
      "transport": "https",
      "max_failures": 5,
      "weight": 1
    }
  ]
}
